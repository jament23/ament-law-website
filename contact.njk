---
layout: layouts/base.njk
title: "Free Consultation"
description: "Schedule a free consultation with the attorneys at Ament Law Group in Murrysville, PA. Estate planning, probate, real estate, and business law."
permalink: /contact/index.html
---
<section class="simple-header">
    <div class="container">
        <h1>Schedule a Free Consultation</h1>
        <p>We're here to help. Schedule your consultation today.</p>
    </div>
</section>
<section id="contact-page">
    <div class="container">
        <div class="contact-layout">
            <div class="contact-info">
                <h3>Our Location</h3>
                <p>3950 William Penn Highway, Floor 1<br>Murrysville, PA 15668</p>
                <h3>General Contact</h3>
                <p><strong>Phone:</strong> <a href="tel:724-733-3500">(724) 733-3500</a><br>
                   <strong>Email:</strong> <a href="mailto:hello@ament.law">hello@ament.law</a></p>
                <h3>Office Hours</h3>
                <p>Monday – Friday: 8:30 AM – 5:00 PM<br>Evenings & weekends by appointment</p>
                <div class="map-embed">
                    <iframe src="https://www.google.com/maps?q=place_id:ChIJn2ClOZ3BNIgREGjpkglfGDs&output=embed&hl=en" width="100%" height="300" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>
            <div class="contact-form">
                <h3>Send Us a Message</h3>
                <p>Fill out the form below and we'll send you a secure intake form to get started.</p>

                <form id="main-contact-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="first-name">First Name <span class="required">*</span></label>
                            <input type="text" id="first-name" name="first_name" required autocomplete="given-name">
                        </div>
                        <div class="form-group">
                            <label for="last-name">Last Name <span class="required">*</span></label>
                            <input type="text" id="last-name" name="last_name" required autocomplete="family-name">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="email">Email <span class="required">*</span></label>
                        <input type="email" id="email" name="email" required autocomplete="email">
                    </div>
                    <div class="form-group">
                        <label for="phone">Phone</label>
                        <input type="tel" id="phone" name="phone" autocomplete="tel">
                    </div>
                    <div class="form-group">
                        <label for="matter-type">How Can We Help? <span class="required">*</span></label>
                        <select id="matter-type" name="matter_type" required>
                            <option value="" disabled selected>Select an area...</option>
                            <option value="estate-planning">Estate Planning (Wills, Trusts, Powers of Attorney)</option>
                            <option value="probate">Probate & Estate Administration</option>
                            <option value="real-estate">Real Estate (Buying, Selling, Closings)</option>
                            <option value="business">Business Law (Formation, Contracts, Counsel)</option>
                            <option value="elder-law">Elder Law & Medicaid Planning</option>
                            <option value="general">Other / Not Sure</option>
                            <option value="marketing">Marketing / Vendor Inquiry</option>
                        </select>
                    </div>

                    <!-- Referral notice for out-of-scope practice areas -->
                    <div id="referral-notice" style="display:none; margin-bottom:16px; padding:14px 16px; background:#f8f6f1; border-left:3px solid #c8a45a; border-radius:4px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c8a45a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px; margin-right:6px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        <strong>A note on this area of law:</strong> We don't handle <span id="referral-area-name">this type of matter</span> in our office, but we can still help — we maintain relationships with trusted attorneys in this area and are glad to connect you with someone we know personally. Please fill out the form and we'll follow up directly.
                    </div>

                    <div class="form-group">
                        <label for="message">Tell Us About Your Situation</label>
                        <textarea id="message" name="message" rows="4" placeholder="Briefly describe what you need help with..."></textarea>
                    </div>

                    <!-- Honeypot — hidden from real users, bots fill it -->
                    <div style="position:absolute;left:-9999px;" aria-hidden="true">
                        <label for="website_url">Website</label>
                        <input type="text" id="website_url" name="website_url" tabindex="-1" autocomplete="off">
                    </div>

                    <!-- Human confirmation -->
                    <div class="form-group confirm-group">
                        <label class="confirm-label">
                            <input type="checkbox" id="confirm-human" required>
                            <span>I confirm this is a genuine inquiry and I am not a robot.</span>
                        </label>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="cta-button" id="submit-btn">
                            Send Message
                        </button>
                    </div>
                    <p class="form-disclaimer">Contacting us does not create an attorney-client relationship. Information submitted is kept confidential.</p>
                </form>

                <div class="form-trust-strip">
                    <div class="form-trust-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        <span>4.9-star rating</span>
                    </div>
                    <div class="form-trust-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        <span>130+ years combined experience</span>
                    </div>
                    <div class="form-trust-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        <span>Free &amp; confidential consultation</span>
                    </div>
                </div>

                <!-- Success message (hidden by default) -->
                <div id="form-success" style="display:none;">
                    <div class="form-success-box">
                        <div class="success-icon">
                            <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#2e6b3e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
                        </div>
                        <h3>Message Received</h3>
                        <p>Thank you for reaching out. We've sent a <strong>secure intake form</strong> to your email — please check your inbox (and spam folder) to get started.</p>
                        <p>If you need immediate assistance, call us at <a href="tel:724-733-3500">(724) 733-3500</a>.</p>
                    </div>
                </div>

                <!-- Error message (hidden by default) -->
                <div id="form-error" style="display:none;">
                    <div class="form-error-box">
                        <p id="error-text">Something went wrong. Please call us at <a href="tel:724-733-3500">(724) 733-3500</a> or email <a href="mailto:hello@ament.law">hello@ament.law</a>.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
(function() {
    var AMENTCASE_URL = 'https://amentcase.com/api/website-lead';
    var PAGE_LOAD_TIME = Date.now();
    var submitting = false;

    var form = document.getElementById('main-contact-form');
    var btn  = document.getElementById('submit-btn');
    var successDiv = document.getElementById('form-success');
    var errorDiv   = document.getElementById('form-error');
    var errorText  = document.getElementById('error-text');
    var confirmBox = document.getElementById('confirm-human');

    form.addEventListener('submit', function(e) {
        e.preventDefault();

        // Prevent double-submit
        if (submitting) return;

        // Bot check 1: honeypot filled
        if (form.website_url.value) return;

        // Bot check 2: submitted too fast (under 3 seconds)
        if (Date.now() - PAGE_LOAD_TIME < 3000) {
            errorText.textContent = 'Please wait a moment before submitting.';
            errorDiv.style.display = 'block';
            return;
        }

        // Bot check 3: checkbox not checked
        if (!confirmBox.checked) {
            errorText.textContent = 'Please confirm you are not a robot.';
            errorDiv.style.display = 'block';
            return;
        }

        // Disable button and lock
        submitting = true;
        btn.disabled = true;
        btn.textContent = 'Sending...';
        errorDiv.style.display = 'none';

        var payload = {
            first_name:  form.first_name.value.trim(),
            last_name:   form.last_name.value.trim(),
            email:       form.email.value.trim(),
            phone:       form.phone.value.trim(),
            matter_type: form.matter_type.value,
            message:     form.message.value.trim(),
            website_url: form.website_url.value,  // honeypot
            _time_on_page: Math.round((Date.now() - PAGE_LOAD_TIME) / 1000)
        };

        fetch(AMENTCASE_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(function(res) {
            if (!res.ok) {
                return res.json().then(function(data) {
                    throw new Error(data.error || 'Server error');
                });
            }
            return res.json();
        })
        .then(function(data) {
            // Success — hide form, show confirmation
            form.style.display = 'none';
            var selectedType = payload.matter_type;
            if (selectedType === 'family-law' || selectedType === 'personal-injury') {
                var areaLabel = selectedType === 'family-law' ? 'family law' : 'personal injury';
                successDiv.innerHTML = '<div class="form-success-box">' +
                    '<div class="success-icon"><svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#2e6b3e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg></div>' +
                    '<h3>We Received Your Message</h3>' +
                    '<p>While we don’t handle ' + areaLabel + ' matters in our office, we have trusted relationships with attorneys who do. A member of our team will reach out to personally connect you with someone we know and trust.</p>' +
                    '<p>If you need to speak with someone sooner, call us at <a href="tel:724-733-3500">(724) 733-3500</a>.</p>' +
                    '</div>';
                successDiv.style.display = 'block';
                return;
            }
            if (data.marketing) {
                // Marketing/vendor inquiry — no intake form
                successDiv.innerHTML = '<div class="form-success-box">' +
                    '<div class="success-icon">✓</div>' +
                    '<h3>Message Received</h3>' +
                    '<p>Thank you for reaching out. A member of our team will review your message and follow up if appropriate.</p>' +
                    '</div>';
            } else if (data.email_sent === false) {
                // API accepted but email failed
                successDiv.innerHTML = '<div class="form-success-box">' +
                    '<div class="success-icon">✓</div>' +
                    '<h3>Message Received</h3>' +
                    '<p>We received your information but had trouble sending the intake form to your email. ' +
                    'Our team has been notified and will follow up with you directly.</p>' +
                    '<p>If you need immediate assistance, call us at <a href="tel:724-733-3500">(724) 733-3500</a>.</p>' +
                    '</div>';
            }
            successDiv.style.display = 'block';
        })
        .catch(function(err) {
            // Error — show message, re-enable button
            errorText.textContent = err.message || 'Something went wrong. Please call us at (724) 733-3500.';
            errorDiv.style.display = 'block';
            submitting = false;
            btn.disabled = false;
            btn.textContent = 'Send Message';
        });
    });
})();

/* Show referral notice for out-of-scope practice areas */
(function() {
    var REFERRAL_TYPES = {
        'family-law':      'family law matters',
        'personal-injury': 'personal injury or accident claims'
    };
    var select = document.getElementById('matter-type');
    var notice = document.getElementById('referral-notice');
    var areaName = document.getElementById('referral-area-name');
    if (!select || !notice) return;
    select.addEventListener('change', function() {
        var label = REFERRAL_TYPES[this.value];
        if (label) {
            areaName.textContent = label;
            notice.style.display = 'block';
        } else {
            notice.style.display = 'none';
        }
    });
})();

/* Pre-fill form when arriving from referral partner page */
(function() {
    var params = new URLSearchParams(window.location.search);
    if (params.get('ref') === 'partner') {
        var mt = document.getElementById('matter-type');
        var msg = document.getElementById('message');
        if (mt) mt.value = 'general';
        if (msg) msg.value = 'I would like to set up a referral portal to refer clients to your firm.';
    }
})();
</script>
