    <script>
    (function() {
        /* Nav toggle */
        var toggle = document.querySelector('.nav-toggle');
        var nav = document.getElementById('main-nav');
        if (toggle && nav) {
            toggle.addEventListener('click', function() {
                var expanded = toggle.getAttribute('aria-expanded') === 'true';
                toggle.setAttribute('aria-expanded', !expanded);
                nav.classList.toggle('nav-open');
                toggle.classList.toggle('active');
                document.body.classList.toggle('nav-is-open');
            });
        }

        /* Dropdown toggles — desktop: navigate on click, hover opens dropdown.
           Mobile: click toggles dropdown (no hover). */
        var isMobile = function() { return window.innerWidth <= 900; };
        var dropdownTriggers = document.querySelectorAll('.has-dropdown > .dropdown-trigger');
        dropdownTriggers.forEach(function(trigger) {
            trigger.addEventListener('click', function(e) {
                var parent = trigger.parentElement;
                if (isMobile()) {
                    /* Mobile: toggle dropdown, don't navigate */
                    e.preventDefault();
                    var wasOpen = parent.classList.contains('dropdown-open');
                    document.querySelectorAll('.has-dropdown.dropdown-open').forEach(function(el) {
                        el.classList.remove('dropdown-open');
                    });
                    if (!wasOpen) parent.classList.add('dropdown-open');
                }
                /* Desktop: allow default navigation (no preventDefault) */
            });
        });

        /* Desktop: open dropdown on hover */
        document.querySelectorAll('.has-dropdown').forEach(function(item) {
            item.addEventListener('mouseenter', function() {
                if (!isMobile()) {
                    document.querySelectorAll('.has-dropdown.dropdown-open').forEach(function(el) {
                        el.classList.remove('dropdown-open');
                    });
                    item.classList.add('dropdown-open');
                }
            });
            item.addEventListener('mouseleave', function() {
                if (!isMobile()) {
                    item.classList.remove('dropdown-open');
                }
            });
        });

        /* Close nav and all dropdowns on outside click */
        document.addEventListener('click', function(e) {
            if (nav && !nav.contains(e.target) && !toggle.contains(e.target)) {
                nav.classList.remove('nav-open');
                toggle.classList.remove('active');
                toggle.setAttribute('aria-expanded', 'false');
                document.body.classList.remove('nav-is-open');
            }
            /* Close desktop dropdowns when clicking outside */
            if (!e.target.closest('.has-dropdown')) {
                document.querySelectorAll('.has-dropdown.dropdown-open').forEach(function(el) {
                    el.classList.remove('dropdown-open');
                });
            }
        });

        /* Also close on Escape key */
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                document.querySelectorAll('.has-dropdown.dropdown-open').forEach(function(el) {
                    el.classList.remove('dropdown-open');
                });
            }
        });

        /* Scroll fade-in */
        var els = document.querySelectorAll('.fade-in');
        if (els.length && 'IntersectionObserver' in window) {
            var obs = new IntersectionObserver(function(entries) {
                entries.forEach(function(e) {
                    if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
                });
            }, { threshold: 0.1 });
            els.forEach(function(el) { obs.observe(el); });
        } else {
            els.forEach(function(el) { el.classList.add('visible'); });
        }
    })();
    </script>
    <script>
    /* Chat Assistant */
    (function() {
        var MAX = 10, count = 0, history = [];
        var panel = document.getElementById('chat-panel');
        var toggle = document.getElementById('chat-toggle');
        var closeBtn = document.getElementById('chat-close');
        var messages = document.getElementById('chat-messages');
        var input = document.getElementById('chat-input');
        var sendBtn = document.getElementById('chat-send');
        var suggestions = document.getElementById('chat-suggestions');
        var remaining = document.getElementById('chat-remaining');
        var inputArea = document.getElementById('chat-input-area');
        var sessionEnded = document.getElementById('chat-session-ended');
        var isOpen = false, loading = false;
        var detectedArea = '';

        function openChat() {
            isOpen = true;
            panel.style.display = 'flex';
            panel.setAttribute('aria-hidden', 'false');
            toggle.setAttribute('aria-expanded', 'true');
            toggle.classList.add('chat-open');
            setTimeout(function() { panel.classList.add('visible'); input.focus(); }, 10);
        }
        function closeChat() {
            isOpen = false;
            panel.classList.remove('visible');
            panel.setAttribute('aria-hidden', 'true');
            toggle.setAttribute('aria-expanded', 'false');
            toggle.classList.remove('chat-open');
            setTimeout(function() { panel.style.display = 'none'; toggle.focus(); }, 300);
        }
        toggle.addEventListener('click', function() { isOpen ? closeChat() : openChat(); });
        closeBtn.addEventListener('click', closeChat);
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && isOpen) closeChat();
        });

        function addMsg(role, text) {
            var div = document.createElement('div');
            div.className = 'chat-msg ' + role;
            text.split('\n').forEach(function(line, i) {
                if (line.trim()) {
                    var p = document.createElement('p');
                    p.textContent = line;
                    if (i > 0) p.style.marginTop = '8px';
                    div.appendChild(p);
                }
            });
            messages.appendChild(div);
            messages.scrollTop = messages.scrollHeight;
        }

        function addContactForm() {
            var div = document.createElement('div');
            div.className = 'chat-msg assistant chat-lead-form';
            div.innerHTML =
                '<form id="chat-lead-form" autocomplete="on">' +
                '<p class="chat-form-label">We\'ll reach out to you shortly:</p>' +
                '<input type="text" name="name" placeholder="Your name" required autocomplete="name">' +
                '<input type="tel" name="phone" placeholder="Phone number" required autocomplete="tel">' +
                '<input type="email" name="email" placeholder="Email (optional)" autocomplete="email">' +
                '<textarea name="notes" placeholder="Anything else we should know?" rows="2"></textarea>' +
                '<button type="submit" class="chat-lead-submit">Request Callback</button>' +
                '</form>';
            messages.appendChild(div);
            messages.scrollTop = messages.scrollHeight;

            div.querySelector('form').addEventListener('submit', function(e) {
                e.preventDefault();
                var form = e.target;
                var btn = form.querySelector('button');
                btn.disabled = true;
                btn.textContent = 'Sending...';

                // Detect area from conversation
                var areaGuess = detectArea();

                fetch('/api/chat-lead', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        name: form.querySelector('[name="name"]').value.trim(),
                        phone: form.querySelector('[name="phone"]').value.trim(),
                        email: form.querySelector('[name="email"]').value.trim(),
                        area: areaGuess,
                        notes: form.querySelector('[name="notes"]').value.trim(),
                        conversation: history
                    })
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.ok) {
                        div.innerHTML = '<p class="chat-form-success">Thank you! Someone from our team will be in touch soon.</p>';
                    } else {
                        btn.disabled = false;
                        btn.textContent = 'Request Callback';
                        addMsg('assistant', 'I had trouble submitting that. You can also reach us directly at (724) 733-3500 or hello@ament.law.');
                    }
                })
                .catch(function() {
                    btn.disabled = false;
                    btn.textContent = 'Request Callback';
                    addMsg('assistant', 'I had trouble submitting that. You can also reach us directly at (724) 733-3500 or hello@ament.law.');
                });
                messages.scrollTop = messages.scrollHeight;
            });

            // Hide regular input while form is showing
            inputArea.style.display = 'none';
            document.querySelector('.chat-meta').style.display = 'none';
        }

        function detectArea() {
            var convo = history.map(function(m) { return m.content; }).join(' ').toLowerCase();
            if (/estate plan|will|trust|power of attorney|poa|healthcare directive/.test(convo)) return 'Estate Planning';
            if (/probate|passed away|died|estate admin|inheritance|executor|letters testamentary/.test(convo)) return 'Probate & Estate Administration';
            if (/real estate|closing|settlement|title|deed|property|house|home|buy|sell|fsbo/.test(convo)) return 'Real Estate';
            if (/business|llc|corp|formation|contract|lease|partnership|entity/.test(convo)) return 'Business Law';
            if (/elder|medicaid|nursing|long.term|guardian|aging/.test(convo)) return 'Elder Law';
            return 'General Inquiry';
        }

        function showTyping() {
            var div = document.createElement('div');
            div.className = 'chat-msg assistant';
            div.id = 'chat-typing';
            div.innerHTML = '<div class="chat-typing"><span></span><span></span><span></span></div>';
            messages.appendChild(div);
            messages.scrollTop = messages.scrollHeight;
        }
        function hideTyping() {
            var el = document.getElementById('chat-typing');
            if (el) el.remove();
        }
        function updateRemaining() {
            var r = MAX - count;
            remaining.textContent = r + (r === 1 ? ' message' : ' messages') + ' remaining';
        }

        async function send(text) {
            if (!text.trim() || loading || count >= MAX) return;
            count++;
            updateRemaining();
            if (suggestions) { suggestions.style.display = 'none'; }
            addMsg('user', text);
            input.value = '';
            sendBtn.disabled = true;
            loading = true;

            history.push({ role: 'user', content: text });
            var isLast = count >= MAX;

            showTyping();
            try {
                var resp = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ messages: history, isLastMessage: isLast })
                });
                var data = await resp.json();
                var reply = data.reply || data.error || "I'm having trouble right now. Please call us at (724) 733-3500.";
                if (data.error) reply = "I'm having trouble right now. Please call us at (724) 733-3500 or visit www.ament.law/contact.";
                hideTyping();

                // Check for contact form trigger
                var showForm = false;
                if (reply.indexOf('[[CONTACT_FORM]]') !== -1) {
                    reply = reply.replace(/\s*\[\[CONTACT_FORM\]\]\s*/g, '').trim();
                    showForm = true;
                }

                addMsg('assistant', reply);
                history.push({ role: 'assistant', content: reply });

                if (showForm) {
                    addContactForm();
                }
            } catch(e) {
                hideTyping();
                addMsg('assistant', "I'm having trouble connecting. The best way to reach us is (724) 733-3500 or www.ament.law/contact.");
            }
            loading = false;
            if (isLast && !document.getElementById('chat-lead-form')) {
                inputArea.style.display = 'none';
                document.querySelector('.chat-meta').style.display = 'none';
                sessionEnded.style.display = 'block';
            } else if (!document.getElementById('chat-lead-form')) {
                sendBtn.disabled = !input.value.trim();
                input.focus();
            }
        }

        input.addEventListener('input', function() { sendBtn.disabled = !input.value.trim() || loading; });
        input.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); send(input.value); } });
        sendBtn.addEventListener('click', function() { send(input.value); });

        document.querySelectorAll('.chat-suggestion').forEach(function(btn) {
            btn.addEventListener('click', function() { send(btn.getAttribute('data-q')); });
        });
    })();
    </script>
    <script>
    function subscribeNewsletter() {
        var emailInput = document.getElementById('newsletter-email');
        var email = emailInput.value.trim();
        var btn = document.getElementById('newsletter-submit');
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            emailInput.style.borderColor = '#dc2626';
            return;
        }
        btn.disabled = true;
        btn.textContent = '...';
        fetch('/api/newsletter-subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.ok) {
                document.getElementById('newsletter-form-wrap').style.display = 'none';
                document.getElementById('newsletter-success').style.display = 'block';
            } else {
                btn.disabled = false;
                btn.textContent = 'Subscribe';
                emailInput.style.borderColor = '#dc2626';
            }
        })
        .catch(function() {
            btn.disabled = false;
            btn.textContent = 'Subscribe';
        });
    }
    document.getElementById('newsletter-email').addEventListener('keydown', function(e) {
        this.style.borderColor = '';
        if (e.key === 'Enter') { e.preventDefault(); subscribeNewsletter(); }
    });
    </script>
</body>
