<script>
var WEEKS = [
  {
    title: 'Week 1', badge: 'Immediate Priorities',
    items: [
      { title: 'Obtain certified copies of the death certificate', detail: 'Request 10-15 certified copies from the funeral home or the county vital records office. You\'ll need these for banks, insurance companies, the Register of Wills, the Social Security Administration, and more. It\'s much easier to get extras now than to order them later.' },
      { title: 'Locate the original will and estate planning documents', detail: 'Check the decedent\'s home (safe, filing cabinet, desk), their attorney\'s office, and any safe deposit box. You\'ll need the <em>original</em> will — not a copy — to file with the Register of Wills. Also look for trusts, powers of attorney, deeds, and beneficiary designation forms.' },
      { title: 'Notify immediate family members and close friends', detail: 'Make sure all close family members are informed. If there are beneficiaries named in the will who live out of state, begin reaching out to them as well.' },
      { title: 'Secure the decedent\'s home, vehicles, and valuables', detail: 'Change locks if necessary, ensure the home is insured and maintained, and take an inventory of any valuable items (jewelry, art, cash, collections). Do not distribute any personal property yet.' },
      { title: 'Contact the decedent\'s employer regarding benefits', detail: 'Ask about any final paycheck, unused vacation payout, pension or retirement benefits, and employer-provided life insurance. Get the HR contact name and any claim forms.' },
      { title: 'Notify the Social Security Administration', detail: 'Call SSA at 1-800-772-1213 to report the death. If the decedent was receiving benefits, they\'ll need to be stopped. The surviving spouse may be eligible for a one-time death benefit of $255 and ongoing survivor benefits.' },
      { title: 'Contact the decedent\'s insurance agent', detail: 'Notify their life insurance, health insurance, homeowner\'s, and auto insurance carriers. File life insurance claims promptly — proceeds are usually paid quickly and are not subject to Pennsylvania inheritance tax. Maintain property insurance on any real estate owned by the estate.' },
    ]
  },
  {
    title: 'Week 2', badge: 'Legal & Financial Steps',
    items: [
      { title: 'Consult an attorney about probate and estate administration', detail: 'An estate attorney can explain the probate process, help you understand your duties as executor or administrator, and handle the court filings and tax returns. <a href="/contact/">Schedule a free consultation</a> with Ament Law Group — we offer flat-fee probate services.' },
      { title: 'File the will with the Register of Wills', detail: 'Bring the <em>original</em> will and a certified death certificate to the Register of Wills in the county where the decedent lived. This is required even if probate isn\'t needed for all assets. In Westmoreland County, the Register is located in the courthouse in Greensburg.' },
      { title: 'Apply for Letters Testamentary or Letters of Administration', detail: 'Letters Testamentary (if there\'s a will) or Letters of Administration (if there isn\'t) grant you legal authority to act on behalf of the estate. Banks, investment firms, and other institutions will require these before they\'ll work with you. You\'ll receive "Short Certificates" as proof of your authority.' },
      { title: 'Obtain an EIN from the IRS for the estate', detail: 'The estate needs its own tax identification number, separate from the decedent\'s Social Security Number. Apply online at <a href="https://www.irs.gov/businesses/small-businesses-self-employed/apply-for-an-employer-identification-number-ein-online" target="_blank" rel="noopener">irs.gov</a> using Form SS-4. This is free and takes about 5 minutes.' },
      { title: 'Open an estate bank account', detail: 'All estate funds should flow through a dedicated estate account — not your personal account. Bring the Letters Testamentary/Administration, death certificate, and estate EIN to the bank. Use this account to pay estate expenses and receive any payments owed to the estate.' },
      { title: 'Notify banks, investment firms, and credit card companies', detail: 'Provide each institution with a death certificate and your Letters. Some accounts may be frozen until you present documentation. Do not close accounts yet — just notify and request account statements.' },
      { title: 'Begin gathering asset and liability information', detail: 'Start building a complete picture of the estate: real estate, bank accounts, investments, retirement accounts, life insurance, vehicles, personal property, and all debts (mortgage, credit cards, medical bills, taxes owed). You\'ll need this for the inheritance tax return and for distribution.' },
    ]
  },
  {
    title: 'Weeks 3-4', badge: 'Notifications & Administration',
    items: [
      { title: 'Publish estate notice in newspaper and county legal journal', detail: 'Pennsylvania law requires you to publish a notice of estate administration in a newspaper of general circulation and the county legal journal. This puts creditors on notice and starts the clock on the one-year creditor claims period. Your attorney typically handles this.' },
      { title: 'Send written notice to known beneficiaries and creditors', detail: 'All beneficiaries named in the will (or intestate heirs if there\'s no will) should receive written notice of your appointment. Known creditors should also be notified in writing. Keep copies of all notices.' },
      { title: 'Redirect the decedent\'s mail', detail: 'File a change of address with the post office to forward the decedent\'s mail to the executor\'s address or the estate\'s mailing address. This helps you catch bills, statements, and correspondence you might otherwise miss.' },
      { title: 'Cancel or transfer utilities, subscriptions, and memberships', detail: 'Review recurring charges on bank and credit card statements. Cancel what\'s no longer needed and transfer utilities to the estate or new owner if the property is being maintained.' },
      { title: 'Review and maintain insurance coverage on estate property', detail: 'Make sure homeowner\'s insurance, auto insurance, and any other property coverage remains active during administration. An uninsured loss during probate can devastate the estate.' },
      { title: 'Begin organizing financial records for tax filings', detail: 'You\'ll need to file the decedent\'s final income tax return and the PA Inheritance Tax Return (REV-1500 or REV-1502). Start gathering W-2s, 1099s, bank statements, and records of all assets and their date-of-death values.' },
      { title: 'File claims for life insurance, retirement, or veterans benefits', detail: 'Life insurance and retirement accounts with named beneficiaries pass outside of probate, but claims still need to be filed. If the decedent was a veteran, contact the VA about burial benefits and any pension or survivor benefits.' },
    ]
  }
];

var STORAGE_KEY = 'ament_30day_progress';
var checked = {};
try { checked = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch(e) {}

function save() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(checked)); } catch(e) {}
}

function render() {
  var container = document.getElementById('cl-weeks');
  var html = '';
  var totalItems = 0;

  WEEKS.forEach(function(week, wi) {
    var weekDone = 0;
    week.items.forEach(function(item, ii) {
      totalItems++;
      if (checked[wi + '-' + ii]) weekDone++;
    });
    var isOpen = wi === 0 || weekDone < week.items.length;

    html += '<div class="cl-week' + (isOpen ? ' open' : '') + '" data-week="' + wi + '">';
    html += '<div class="cl-week-header" onclick="toggleWeek(this)">';
    html += '<h3><span class="cl-week-badge">' + week.badge + '</span> ' + week.title + '</h3>';
    html += '<div style="display:flex;align-items:center;gap:12px;"><span class="cl-week-count">' + weekDone + '/' + week.items.length + '</span>';
    html += '<svg class="cl-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></div></div>';
    html += '<div class="cl-week-body">';

    week.items.forEach(function(item, ii) {
      var key = wi + '-' + ii;
      var isDone = checked[key];
      html += '<div class="cl-item' + (isDone ? ' done' : '') + '">';
      html += '<input type="checkbox"' + (isDone ? ' checked' : '') + ' onchange="toggleItem(' + wi + ',' + ii + ',this)">';
      html += '<div class="cl-item-content">';
      html += '<div class="cl-item-title" onclick="toggleDetail(this)">' + item.title + '</div>';
      html += '<div class="cl-item-detail">' + item.detail + '</div>';
      html += '</div></div>';
    });

    html += '</div></div>';
  });

  container.innerHTML = html;
  updateProgress();
}

function updateProgress() {
  var total = 0, done = 0;
  WEEKS.forEach(function(week, wi) {
    week.items.forEach(function(item, ii) {
      total++;
      if (checked[wi + '-' + ii]) done++;
    });
  });
  document.getElementById('cl-done').textContent = done;
  document.getElementById('cl-total').textContent = total;
  document.getElementById('cl-bar').style.width = (total > 0 ? (done / total * 100) : 0) + '%';
}

function toggleWeek(header) {
  header.parentElement.classList.toggle('open');
}

function toggleItem(wi, ii, cb) {
  var key = wi + '-' + ii;
  checked[key] = cb.checked;
  cb.closest('.cl-item').classList.toggle('done', cb.checked);
  save();
  updateProgress();
  // Update week count
  var weekEl = cb.closest('.cl-week');
  var weekIdx = parseInt(weekEl.getAttribute('data-week'));
  var weekDone = 0;
  WEEKS[weekIdx].items.forEach(function(item, i) {
    if (checked[weekIdx + '-' + i]) weekDone++;
  });
  weekEl.querySelector('.cl-week-count').textContent = weekDone + '/' + WEEKS[weekIdx].items.length;
}

function toggleDetail(titleEl) {
  var detail = titleEl.nextElementSibling;
  detail.style.display = detail.style.display === 'block' ? 'none' : 'block';
}

render();
</script>
